# Production CORS settings
# Comma-separated list of allowed origins (leave empty for development)
# Example: ALLOWED_ORIGINS=https://purrdrop.com,https://www.purrdrop.com
ALLOWED_ORIGINS=

# TURN Server Credentials (optional - defaults provided)
# Get your own from https://www.metered.ca/tools/openrelay/ or other TURN providers
TURN_USERNAME=
TURN_CREDENTIAL=

# Next.js Optimization (Recommended for Render Free Tier)
# Disable telemetry to save build time and memory
NEXT_TELEMETRY_DISABLED=1
